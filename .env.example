VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# Expedicao Integration (mesma URL, chaves diferentes por loja)
EXPEDICAO_API_KEY=          # chave Newshop
EXPEDICAO_API_KEY_SF=       # chave Soye e Facil

# ERP / Varejo Facil API
# NAO vao mais na Vercel — vivem como secrets das Supabase Edge Functions
# erp-proxy / erp-image-proxy (supabase secrets set NOME=valor, ou pelo dashboard
# Project Settings > Edge Functions > Secrets). Sem prefixo VITE_ (Deno nao usa isso).
# So precisa de um jeito de autenticar por empresa: USERNAME+PASSWORD (login automatico,
# recomendado) OU TOKEN fixo (nao se renova sozinho se expirar).
ERP_API_USERNAME_NEWSHOP=
ERP_API_PASSWORD_NEWSHOP=
ERP_API_TOKEN_NEWSHOP=
ERP_API_URL_NEWSHOP=https://newshop.varejofacil.com

ERP_API_USERNAME_FACIL=
ERP_API_PASSWORD_FACIL=
ERP_API_TOKEN_FACIL=
ERP_API_URL_FACIL=https://facil.varejofacil.com

# SOYE usa o mesmo host do FACIL, mas pode ter credencial propria (a especifica
# sempre vence a do FACIL, se as duas existirem).
ERP_API_USERNAME_SOYE=
ERP_API_PASSWORD_SOYE=
ERP_API_TOKEN_SOYE=

# Fallback geral (usado so se nao houver variante por empresa)
ERP_API_USERNAME=
ERP_API_PASSWORD=
ERP_API_TOKEN=

# Sync de fotos do APP para o ERP (Trigger.dev — env separado do Supabase/Vercel)
# Habilitar com "true" para que fotos tiradas no app subam para o cadastro do produto no ERP.
ERP_FOTO_SYNC_ENABLED=false
